---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'Skateland West',
		description: 'Client website for a San Antonio skating rink. Built with Next.js and Payload CMS.',
		tech: ['Next.js', 'Payload CMS', 'Postgres', 'TypeScript'],
		url: 'https://skateland.buford.dev',
	},
	{
		title: 'SAMA Companion',
		description: 'Practice companion app for music lessons. Local-first with SQLite sync.',
		tech: ['Expo', 'SQLite', 'TypeScript'],
		url: 'https://sama.buford.dev',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Hey, I'm Buford.</h1>
				<p>
					Developer and musician based in San Antonio, TX. I build web apps, self-host my
					infrastructure, and write about what I learn along the way.
				</p>
			</section>

			<section class="projects">
				<h2>Projects</h2>
				<ul class="project-grid">
					{projects.map((project) => (
						<li class="project-card">
							<a href={project.url}>
								<h3>{project.title}</h3>
								<p>{project.description}</p>
								<div class="tech-tags">
									{project.tech.map((t) => (
										<span class="tag">{t}</span>
									))}
								</div>
							</a>
						</li>
					))}
				</ul>
				<p class="more-link"><a href="/projects">View all projects &rarr;</a></p>
			</section>

			<section class="recent-posts">
				<h2>Recent Writing</h2>
				<p>Thoughts on development, music, and self-hosting.</p>
				<p class="more-link"><a href="/blog">Read the blog &rarr;</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3rem;
	}
	.hero h1 {
		font-size: 2.5em;
		margin-bottom: 0.5rem;
	}
	.hero p {
		font-size: 1.1em;
		color: rgb(var(--gray));
	}
	.projects {
		margin-bottom: 3rem;
	}
	.project-grid {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.project-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		transition: box-shadow 0.2s ease;
	}
	.project-card:hover {
		box-shadow: var(--box-shadow);
	}
	.project-card a {
		display: block;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
	}
	.project-card h3 {
		margin-bottom: 0.5rem;
		color: rgb(var(--black));
	}
	.project-card p {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin-bottom: 1rem;
	}
	.tech-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		font-size: 0.75em;
	}
	.more-link {
		margin-top: 1rem;
	}
	.recent-posts {
		margin-bottom: 3rem;
	}
</style>
