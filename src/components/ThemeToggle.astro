<button id="theme-toggle" aria-label="Toggle theme" role="switch" aria-checked="false">
	<span class="toggle-track">
		<span class="star s1"></span>
		<span class="star s2"></span>
		<span class="star s3"></span>
		<span class="star s4"></span>
		<span class="star s5"></span>
		<span class="cloud c1"></span>
		<span class="cloud c2"></span>
		<span class="cloud c3"></span>
		<span class="toggle-knob">
			<svg class="icon-sun" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
				<circle cx="12" cy="12" r="4.5" fill="#f39c12" />
				<g stroke="#f39c12" stroke-width="2" stroke-linecap="round">
					<line x1="12" y1="1.5" x2="12" y2="4.5" />
					<line x1="12" y1="19.5" x2="12" y2="22.5" />
					<line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
					<line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
					<line x1="1.5" y1="12" x2="4.5" y2="12" />
					<line x1="19.5" y1="12" x2="22.5" y2="12" />
					<line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
					<line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
				</g>
			</svg>
			<svg class="icon-moon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
				<path fill="#b0b4c8" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
				<circle cx="14" cy="9" r="1.2" fill="#9a9eb5" opacity="0.6" />
				<circle cx="11" cy="14" r="0.8" fill="#9a9eb5" opacity="0.4" />
			</svg>
		</span>
	</span>
</button>

<style is:global>
	#theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 2px;
		display: flex;
		align-items: center;
		-webkit-tap-highlight-color: transparent;
	}

	#theme-toggle:focus-visible .toggle-track {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.toggle-track {
		position: relative;
		width: 60px;
		height: 30px;
		border-radius: 15px;
		background: linear-gradient(135deg, #f5af19, #f39c12, #e67e22);
		transition: background 0.5s ease, box-shadow 0.3s ease;
		overflow: hidden;
	}

	[data-theme="dark"] .toggle-track {
		background: linear-gradient(135deg, #0d1b3e, #162550, #1a2d6b);
	}

	#theme-toggle:hover .toggle-track {
		box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
	}

	/* Sliding knob */
	.toggle-knob {
		position: absolute;
		top: 3px;
		left: 3px;
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.5s cubic-bezier(0.68, -0.15, 0.27, 1.15);
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
		z-index: 2;
		will-change: transform;
	}

	[data-theme="dark"] .toggle-knob {
		transform: translateX(30px);
		background: #d0d4e0;
	}

	/* Sun icon */
	.toggle-knob .icon-sun {
		position: absolute;
		opacity: 1;
		transform: rotate(0deg) scale(1);
		transition: opacity 0.3s ease, transform 0.5s ease;
	}

	[data-theme="dark"] .toggle-knob .icon-sun {
		opacity: 0;
		transform: rotate(180deg) scale(0.5);
	}

	/* Moon icon */
	.toggle-knob .icon-moon {
		position: absolute;
		opacity: 0;
		transform: rotate(-180deg) scale(0.5);
		transition: opacity 0.3s ease, transform 0.5s ease;
	}

	[data-theme="dark"] .toggle-knob .icon-moon {
		opacity: 1;
		transform: rotate(0deg) scale(1);
	}

	/* Stars */
	.star {
		position: absolute;
		background: #fff;
		border-radius: 50%;
		opacity: 0;
		transition: opacity 0.4s ease 0.15s;
		z-index: 1;
	}

	[data-theme="dark"] .star {
		opacity: 1;
	}

	.s1 { top: 7px; left: 10px; width: 2px; height: 2px; }
	.s2 { top: 16px; left: 16px; width: 3px; height: 3px; }
	.s3 { top: 5px; left: 22px; width: 2px; height: 2px; }
	.s4 { top: 20px; left: 8px; width: 2px; height: 2px; }
	.s5 { top: 12px; left: 6px; width: 1.5px; height: 1.5px; }

	@keyframes twinkle {
		0%, 100% { opacity: 0.5; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.3); }
	}

	[data-theme="dark"] .s1 { animation: twinkle 3s ease-in-out infinite; }
	[data-theme="dark"] .s2 { animation: twinkle 2.5s ease-in-out 0.7s infinite; }
	[data-theme="dark"] .s3 { animation: twinkle 4s ease-in-out 1.2s infinite; }
	[data-theme="dark"] .s4 { animation: twinkle 3.5s ease-in-out 0.3s infinite; }
	[data-theme="dark"] .s5 { animation: twinkle 2.8s ease-in-out 1.8s infinite; }

	/* Clouds */
	.cloud {
		position: absolute;
		background: rgba(255, 255, 255, 0.5);
		border-radius: 10px;
		opacity: 1;
		transition: opacity 0.3s ease, transform 0.4s ease;
		z-index: 1;
	}

	[data-theme="dark"] .cloud {
		opacity: 0;
		transform: translateX(5px);
	}

	.c1 { bottom: 8px; right: 6px; width: 14px; height: 5px; }
	.c2 { bottom: 14px; right: 14px; width: 10px; height: 4px; }
	.c3 { bottom: 10px; right: 22px; width: 8px; height: 3px; }
</style>

<script is:inline>
	const toggle = document.getElementById('theme-toggle');

	toggle.setAttribute('aria-checked', document.documentElement.getAttribute('data-theme') === 'dark');

	toggle.addEventListener('click', () => {
		const current = document.documentElement.getAttribute('data-theme');
		const next = current === 'dark' ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
		toggle.setAttribute('aria-checked', next === 'dark');
	});
</script>
